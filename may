<section id="cake-section">
  <div class="divider"></div>
  <div class="cake-label">Make a wish</div>
  <div class="cake-title">Click to cut your cake &#x1F382;</div>
  <canvas id="cake-canvas" width="280" height="260"></canvas>
  <div class="cake-hint" id="cakeHint">tap the cake!</div>
  <div id="cake-msg"></div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-quote">"Are not two sparrows sold for a penny? Yet not one of them will fall to the ground outside your Father&#39;s care."</div>
  <div class="footer-verse">Matthew 10:29</div>
</footer>

<script>
const PRAYERS=[
{img:"data:image/jpeg;base64,",prayer:"Peace that surpasses all understanding",quote:"Sya magbibigay saatin ng peace",date:"Jan 03",icon:"&#x1F54A;&#xFE0F;"},
{img:"data:image/jpeg;base64,",prayer:"Growth in faith, one step at a time",quote:"Kaya gusto kong maging strong sa faith",date:"Aug 19",icon:"&#x1F331;"},
{img:"data:image/jpeg;base64,",prayer:"Grace to love yourself as God loves you",quote:"God\'s love is unconditional",date:"Jul 26",icon:"&#x1F49C;"},
{img:"data:image/jpeg;base64,",prayer:"Joy found in His presence, not the world",quote:"...your grief will turn to joy.",date:"Aug 10",icon:"&#x2728;"},
{img:"data:image/jpeg;base64,",prayer:"Healing for every wound you carry quietly",quote:"Healing doesnt come from running",date:"Aug 08",icon:"&#x1F33F;"},
{img:"data:image/jpeg;base64,",prayer:"Courage to be fully, beautifully yourself",quote:"Takot na takot lang talaga ako ipakita yung totoong ako",date:"Jul 26",icon:"&#x1F917;"},
{img:"data:image/jpeg;base64,",prayer:"Bold courage that goes beyond the screen",quote:"Yung tapang ko pang online lang eh",date:"Aug 25",icon:"&#x1F64F;"},
];

// CANVAS SETUP
const starsCanvas=document.getElementById('stars-canvas');
const sCtx=starsCanvas.getContext('2d');
const confCanvas=document.getElementById('confetti-canvas');
const cCtx=confCanvas.getContext('2d');
function resize(){starsCanvas.width=confCanvas.width=window.innerWidth;starsCanvas.height=confCanvas.height=window.innerHeight;}
resize();window.addEventListener('resize',resize);

// STARS
const STAR_COLORS=['#b39ddb','#a1887f','#fdf6ee','#6b4fa0'];
const stars=Array.from({length:160},()=>({x:Math.random(),y:Math.random(),r:Math.random()*1.4+0.3,a:Math.random(),speed:Math.random()*0.004+0.001,phase:Math.random()*Math.PI*2}));
function drawStars(t){
  sCtx.clearRect(0,0,starsCanvas.width,starsCanvas.height);
  stars.forEach(s=>{
    const alpha=s.a*(0.5+0.5*Math.sin(t*s.speed*60+s.phase));
    sCtx.beginPath();sCtx.arc(s.x*starsCanvas.width,s.y*starsCanvas.height,s.r,0,Math.PI*2);
    sCtx.fillStyle=STAR_COLORS[Math.floor(s.r*2)%STAR_COLORS.length];sCtx.globalAlpha=alpha;sCtx.fill();
  });sCtx.globalAlpha=1;
}

// CONFETTI
let confPieces=[],confActive=false;
const CONF_COLORS=['#b39ddb','#6b4fa0','#a1887f','#c9a84c','#fdf6ee'];
function launchConfetti(){
  confPieces=Array.from({length:180},()=>({x:Math.random()*confCanvas.width,y:-10-Math.random()*80,vx:(Math.random()-0.5)*3.5,vy:Math.random()*3+2,rot:Math.random()*360,rotV:(Math.random()-0.5)*7,w:Math.random()*9+4,h:Math.random()*5+3,color:CONF_COLORS[Math.floor(Math.random()*CONF_COLORS.length)],alpha:1}));
  confActive=true;
}
function drawConfetti(){
  cCtx.clearRect(0,0,confCanvas.width,confCanvas.height);
  if(!confActive)return;
  let alive=0;
  confPieces.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.rot+=p.rotV;p.vy+=0.06;if(p.y<confCanvas.height+20)alive++;
    cCtx.save();cCtx.globalAlpha=Math.max(0,p.alpha);cCtx.translate(p.x,p.y);cCtx.rotate(p.rot*Math.PI/180);cCtx.fillStyle=p.color;cCtx.fillRect(-p.w/2,-p.h/2,p.w,p.h);cCtx.restore();});
  if(alive===0)confActive=false;
}
function loop(t){drawStars(t/1000);drawConfetti();requestAnimationFrame(loop);}
requestAnimationFrame(loop);

// GATE
let wrongCount=0;
function checkAnswer(btn,correct){
  if(correct){
    btn.classList.add('correct');btn.innerHTML='July 5 &#x2714;';
    launchConfetti();
    setTimeout(()=>{
      document.getElementById('gate').classList.add('hide');
      setTimeout(()=>{document.getElementById('gate').style.display='none';startHero();},800);
    },700);
  } else {
    wrongCount++;btn.classList.add('wrong');
    document.getElementById('gateHint').classList.add('show');
    setTimeout(()=>btn.classList.remove('wrong'),500);
  }
}
function startHero(){
  setTimeout(()=>document.getElementById('ageBadge').classList.add('visible'),300);
  setTimeout(()=>document.getElementById('heroName').classList.add('visible'),600);
  setTimeout(()=>document.getElementById('heroSub').classList.add('visible'),900);
  setTimeout(()=>{
    document.getElementById('music-bar').classList.add('show');
    tryAutoplay();
  },1400);
}

// MUSIC
const audio=document.getElementById('bgMusic');
let musicPlaying=false;
function tryAutoplay(){
  audio.volume=0.5;
  audio.play().then(()=>{musicPlaying=true;updateMusicUI();}).catch(()=>{});
}
function toggleMusic(){
  if(musicPlaying){audio.pause();musicPlaying=false;}
  else{audio.play();musicPlaying=true;}
  updateMusicUI();
}
function updateMusicUI(){
  document.getElementById('musicBtn').innerHTML=musicPlaying?'&#9646;&#9646;':'&#9654;';
  const bars=document.getElementById('musicBars');
  if(musicPlaying)bars.classList.remove('paused');else bars.classList.add('paused');
}

// ENVELOPE
let envOpened=false;
function openEnvelope(){
  if(envOpened)return;envOpened=true;
  document.getElementById('envelope').classList.add('open');
  document.getElementById('openHint').style.display='none';
  const c=document.getElementById('letterCard');c.classList.add('show');
  requestAnimationFrame(()=>requestAnimationFrame(()=>c.classList.add('animate')));
  launchConfetti();
}

// LIFE COUNTER from June 14, 2006
function updateLifeCounter(){
  const born=new Date('2006-06-14T00:00:00');
  const now=new Date();
  const diff=now-born;
  const totalSecs=Math.floor(diff/1000);
  const years=Math.floor(diff/(365.25*24*3600*1000));
  const afterYears=new Date(born);afterYears.setFullYear(afterYears.getFullYear()+years);
  let months=0;const tmp=new Date(afterYears);
  while(true){tmp.setMonth(tmp.getMonth()+1);if(tmp>now)break;months++;}
  const afterMonths=new Date(afterYears);afterMonths.setMonth(afterMonths.getMonth()+months);
  const days=Math.floor((now-afterMonths)/(24*3600*1000));
  const hours=Math.floor((totalSecs%86400)/3600);
  const mins=Math.floor((totalSecs%3600)/60);
  const secs=totalSecs%60;
  document.getElementById('lc-years').textContent=years;
  document.getElementById('lc-months').textContent=months;
  document.getElementById('lc-days').textContent=days;
  document.getElementById('lc-hours').textContent=String(hours).padStart(2,'0');
  document.getElementById('lc-mins').textContent=String(mins).padStart(2,'0');
  document.getElementById('lc-secs').textContent=String(secs).padStart(2,'0');
}
updateLifeCounter();setInterval(updateLifeCounter,1000);

// WISH CARDS SCROLL REVEAL
const wishCards=document.querySelectorAll('.wish-card');
const obs=new IntersectionObserver((entries)=>{
  entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('visible'),i*100);});
},{threshold:0.1});
wishCards.forEach(c=>obs.observe(c));

// LIGHTBOX
let lbIndex=0;
function openLightbox(i){
  lbIndex=i;renderLightbox();
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow='hidden';
}
function renderLightbox(){
  const p=PRAYERS[lbIndex];
  document.getElementById('lb-img').src=p.img;
  document.getElementById('lb-prayer').textContent=p.prayer;
  document.getElementById('lb-quote').innerHTML='"'+p.quote+'" &mdash; '+p.date;
}
function lbNav(dir){lbIndex=(lbIndex+dir+PRAYERS.length)%PRAYERS.length;renderLightbox();}
function closeLightbox(){document.getElementById('lightbox').classList.remove('open');document.body.style.overflow='';}
function closeLightboxOutside(e){if(e.target===document.getElementById('lightbox'))closeLightbox();}

// CAKE
const cc=document.getElementById('cake-canvas');
const ctx=cc.getContext('2d');
let cakeCut=false,cakeCutProgress=0,cakeAnimating=false;

function drawCake(progress){
  ctx.clearRect(0,0,280,260);
  const cx=140,cy=170;
  // plate
  ctx.beginPath();ctx.ellipse(cx,220,90,18,0,0,Math.PI*2);
  ctx.fillStyle='rgba(179,157,219,0.15)';ctx.fill();
  // cake body
  ctx.beginPath();ctx.ellipse(cx,180,80,20,0,0,Math.PI*2);
  ctx.fillStyle='#6d4c41';ctx.fill();
  ctx.beginPath();ctx.rect(cx-80,110,160,70);
  ctx.fillStyle='#6d4c41';ctx.fill();
  ctx.beginPath();ctx.ellipse(cx,110,80,20,0,0,Math.PI*2);
  ctx.fillStyle='#795548';ctx.fill();
  // frosting top
  ctx.beginPath();
  for(let i=0;i<=160;i+=10){
    const x=cx-80+i,y=110-8*Math.sin(i*0.2);
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  }
  ctx.lineTo(cx+80,110);ctx.lineTo(cx-80,110);ctx.closePath();
  ctx.fillStyle='#b39ddb';ctx.fill();
  // frosting drips
  [40,70,105,135].forEach(x=>{
    ctx.beginPath();ctx.moveTo(cx-80+x,110);ctx.quadraticCurveTo(cx-80+x+5,125,cx-80+x,135);
    ctx.lineWidth=8;ctx.strokeStyle='#b39ddb';ctx.lineCap='round';ctx.stroke();
  });
  // layer line
  ctx.beginPath();ctx.moveTo(cx-80,145);ctx.lineTo(cx+80,145);
  ctx.strokeStyle='rgba(179,157,219,0.4)';ctx.lineWidth=2;ctx.stroke();
  // candles
  const candleX=[cx-35,cx,cx+35];
  candleX.forEach((x,i)=>{
    ctx.fillStyle='#a1887f';ctx.fillRect(x-4,85,8,25);
    // flame
    if(progress<0.6){
      const flicker=Math.sin(Date.now()*0.008+i)*2;
      ctx.beginPath();ctx.ellipse(x+flicker,80,4,8,0,0,Math.PI*2);
      ctx.fillStyle='#c9a84c';ctx.fill();
      ctx.beginPath();ctx.ellipse(x+flicker,78,2,4,0,0,Math.PI*2);
      ctx.fillStyle='white';ctx.fill();
    }
  });
  // cut slice
  if(progress>0){
    ctx.save();ctx.globalAlpha=progress;
    const sliceAngle=progress*0.8;
    ctx.beginPath();ctx.moveTo(cx,110);
    ctx.arc(cx,180,80,-Math.PI/2,-Math.PI/2+sliceAngle);ctx.closePath();
    ctx.fillStyle='rgba(253,246,238,0.15)';ctx.fill();
    ctx.strokeStyle='rgba(253,246,238,0.5)';ctx.lineWidth=1.5;ctx.stroke();
    ctx.restore();
  }
  // candle glow when blown
  if(progress>=0.6){
    candleX.forEach(x=>{
      ctx.beginPath();ctx.arc(x,80,3,0,Math.PI*2);
      ctx.fillStyle='rgba(201,168,76,0.3)';ctx.fill();
    });
  }
}

function animateCake(){
  requestAnimationFrame(()=>{
    drawCake(cakeCutProgress);
    if(cakeAnimating&&cakeCutProgress<1){
      cakeCutProgress+=0.025;requestAnimationFrame(animateCake);
    } else if(cakeCutProgress>=1){
      cakeCutProgress=1;drawCake(1);cakeAnimating=false;
      launchConfetti();launchConfetti();
      document.getElementById('cakeHint').style.display='none';
      const msg=document.getElementById('cake-msg');
      msg.innerHTML='Happy 20th, Atecuu! &#x1F382;<br><span style="font-size:0.85rem;color:var(--mocha)">May this year be filled with His love, joy, and every blessing.</span>';
      msg.classList.add('show');
    }
  });
}

cc.addEventListener('click',()=>{
  if(!cakeCut){cakeCut=true;cakeAnimating=true;animateCake();}
  else{launchConfetti();}
});

// initial cake draw with flicker
function cakeFlicker(){drawCake(0);if(!cakeCut)requestAnimationFrame(cakeFlicker);}
cakeFlicker();
</script>
</body>
</html>
